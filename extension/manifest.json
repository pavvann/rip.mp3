{
  "manifest_version": 3,
  "name": "rip.mp3 — DJ Track Downloader",
  "version": "1.0.0",
  "description": "Inject download buttons into Spotify and Beatport. 320kbps MP3, normalized, tagged.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://open.spotify.com/*",
    "https://www.beatport.com/*",
    "http://localhost:7823/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "rip.mp3"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.beatport.com/*"],
      "js": ["beatport.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
